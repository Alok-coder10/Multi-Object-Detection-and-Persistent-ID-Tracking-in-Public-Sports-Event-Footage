{
  "_comment": "Default configuration for Sports Tracking Pipeline",
  "_source_note": "Override any key via CLI args or by creating a custom config JSON",

  "output_dir": "outputs",

  "model": "yolov8m.pt",
  "device": "cpu",

  "det_conf": 0.35,
  "det_iou": 0.45,
  "classes": [0, 32],

  "max_age": 30,
  "min_hits": 3,
  "iou_high": 0.30,
  "iou_low": 0.20,
  "high_conf_thresh": 0.50,
  "low_conf_thresh": 0.10,

  "frame_skip": 1,

  "show_trail": true,
  "trail_thickness": 2,
  "box_thickness": 2,
  "show_conf": true
}
